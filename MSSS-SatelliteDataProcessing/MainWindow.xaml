<Window x:Class="MSSS_SatelliteDataProcessing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wpfx="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:MSSS_SatelliteDataProcessing"
        mc:Ignorable="d"
        Title="Marlin Space Science Systems" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen" Background="Transparent">

    <Border Padding="20" Background="#f8f7f9">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Border CornerRadius="25">
                <Border.Background>
                    <LinearGradientBrush>
                        <GradientStop Color="#e2d4e0" Offset="0"/>
                        <GradientStop Color="#8488b5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel>
                <StackPanel HorizontalAlignment="Center" Margin="0, 10, 0, 10">
                    <Grid>
                        <Label Content="M S S S" FontSize="60" HorizontalAlignment="Center" FontFamily="Century Gothic"/>
                        <Label Content="Marlin Space Science Systems" HorizontalAlignment="Center" Margin="0, 68, 0, 0" FontSize="10" FontFamily="Century Gothic"/>
                    </Grid>
                </StackPanel>


                <StackPanel Orientation="Horizontal" Margin="0, 10, 0, 0">
                    <!-- Numeric Control for Standard Deviation -->
                    <Label Content="Sigma" FontFamily="Century Gothic" FontSize="14" Padding="40, 5, 20, 5"/>
                    <Border BorderThickness="0.5" BorderBrush="Gray" HorizontalAlignment="Left" VerticalAlignment="Top" Height="30" Width="80">
                        <wpfx:IntegerUpDown x:Name="txtSigma" Value="10" FontFamily="Century Gothic" FontSize="12" Padding="10 0 0 0" Height="30" Width="80"
                                            VerticalAlignment="Center"  HorizontalAlignment="Center" TextAlignment="Left" Background="Transparent" BorderThickness="0"   
                                            FormatString="N0" />
                    </Border>

                    <!-- Numeric Control for Mean -->
                    <Label Content="Mu" FontFamily="Century Gothic" FontSize="14" Padding="60, 5, 20, 5"/>
                    <Border BorderThickness="0.5" BorderBrush="Gray" HorizontalAlignment="Left" VerticalAlignment="Top" Height="30" Width="80">
                        <wpfx:IntegerUpDown x:Name="txtMean" Value="50" FontFamily="Century Gothic" FontSize="12" Padding="10 0 0 0" Height="30" Width="80"
                                            VerticalAlignment="Center"  HorizontalAlignment="Center" TextAlignment="Left" Background="Transparent" BorderThickness="0"   
                                            FormatString="N0"/>
                    </Border>
                </StackPanel>

                <!-- Button to Load Sensor Data -->
                <Button x:Name="btnLoadData" Content="Load Sensor Data" FontFamily="Century Gothic" FontSize="12" Height="30" Width="325" Grid.Column="1" 
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0, 10, 0, 10"  Click="btnLoadData_Click" Style="{StaticResource ChangeHoverColor}"/>

                <!-- Two column ListView for Sensor Data-->
                <StackPanel Orientation="Vertical" Width="325" Margin="0, 0, 0, 50">
                    <ListView x:Name="lvSensorData" FontFamily="Century Gothic" FontSize="12" Padding="0, 2, 2, 0" MaxHeight="460" ItemContainerStyle="{StaticResource ChangeHoverColorListView}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Sensor A" DisplayMemberBinding="{Binding SensorA}" Width="150"/>
                                <GridViewColumn Header="Sensor B" DisplayMemberBinding="{Binding SensorB}" Width="150"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
                
            </StackPanel>

            <Border Grid.Column="1" Grid.ColumnSpan="2" Margin="10">
                <Label Content="Sensor A" FontFamily="Century Gothic" FontSize="30" Margin="25,80,0,0"/>
            </Border>

            <Border Grid.Column="1" Margin="10" HorizontalAlignment="Center">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,170,0,0">
                    
                    <!-- Sensor A: Binary Search Iterative -->
                    <Label Content="Binary Search Iterative" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Center"/>
                    <Button x:Name="btnBinarySearchIterativeA" Content="Search" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnBinarySearchIterativeA_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtBinaryIterativeA" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>

                    <!-- Sensor A: Binary Search Recursive -->
                    <Label Content="Binary Search Recursive" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Center"/>
                    <Button x:Name="btnBinarySearchRecursiveA" Content="Search" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnBinarySearchRecursiveA_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtBinaryRecursiveA" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>
                    
                    <!-- Sensor A: Search Target -->
                    <Label Content="Search Target" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Left" />
                    <TextBox x:Name="txtTargetA" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" PreviewTextInput="NumericOnly_PreviewTextInput"/>
                
                    <!-- Sensor A: Selection Sort -->
                    <Label Content="Selection Sort" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Left"/>
                    <Button x:Name="btnSelectionSortA" Content="Sort" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnSelectionSortA_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtSelectionSortA" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>
                
                    <!-- Sesnsor A: Insertion Sort -->
                    <Label Content="Insertion Sort" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Left"/>
                    <Button x:Name="btnInsertionSortA" Content="Sort" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnInsertionSortA_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtInsertionSortA" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>
                </StackPanel>
            </Border>

            <!-- Sensor A Listbox -->
            <ListBox x:Name="lstSensorA" SelectionMode="Multiple" FontFamily="Century Gothic" FontSize="12" Padding="0, 2, 2, 0" Margin="0, 185, 0,50" Grid.Column="2" ItemContainerStyle="{StaticResource ChangeSelectedItemBackground}"/>

            <Border Grid.Column="3" Grid.ColumnSpan="2" Margin="10">
                <Label Content="Sensor B" FontFamily="Century Gothic" FontSize="30" Margin="25,80,0,0"/>
            </Border>

            <Border Grid.Column="3" Margin="10" HorizontalAlignment="Center">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,170,0,0">

                    <!-- Sensor B: Binary Search Iterative -->
                    <Label Content="Binary Search Iterative" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Center"/>
                    <Button x:Name="btnBinarySearchIterativeB" Content="Search" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnBinarySearchIterativeB_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtBinaryIterativeB" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>

                    <!-- Sensor B: Binary Search Recursive -->
                    <Label Content="Binary Search Recursive" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Center"/>
                    <Button x:Name="btnBinarySearchRecursiveB" Content="Search" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnBinarySearchRecursiveB_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtBinaryRecursiveB" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>

                    <!-- Sensor B: Search Target -->
                    <Label Content="Search Target" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Left" />
                    <TextBox x:Name="txtTargetB" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" PreviewTextInput="NumericOnly_PreviewTextInput"/>

                    <!-- Sensor B: Selection Sort -->
                    <Label Content="Selection Sort" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Left"/>
                    <Button x:Name="btnSelectionSortB" Content="Sort" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnSelectionSortB_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtSelectionSortB" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>

                    <!-- Sesnsor B: Insertion Sort -->
                    <Label Content="Insertion Sort" Margin="8, 20, 0, 0" FontFamily="Century Gothic" FontSize="14" HorizontalAlignment="Left"/>
                    <Button x:Name="btnInsertionSortB" Content="Sort" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Click="btnInsertionSortB_Click" Style="{StaticResource ChangeHoverColor}"/>
                    <TextBox x:Name="txtInsertionSortB" FontFamily="Century Gothic" FontSize="12" Width="150" Height="25" Margin="5" TextWrapping="Wrap" IsReadOnly="True"/>
                </StackPanel>
            </Border>
            
            <!-- Sensor B Listbox -->
            <ListBox x:Name="lstSensorB" SelectionMode="Multiple" FontFamily="Century Gothic" FontSize="12" Padding="0, 2, 2, 0" Margin="0, 185, 0,50" Grid.Column="4" ItemContainerStyle="{StaticResource ChangeSelectedItemBackground}"/>

        </Grid>
    </Border>
</Window>
