<Window x:Class="MSSS_SatelliteDataProcessing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wpfx="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:MSSS_SatelliteDataProcessing"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <Grid>
        <!-- Two column ListView for Sensor Data-->
        <ListView x:Name="lvSensorData" Margin="10,99,592,10" FontFamily="Century Gothic" FontSize="11">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Sensor A" DisplayMemberBinding="{Binding SensorA}" Width="80"/>
                    <GridViewColumn Header="Sensor B" DisplayMemberBinding="{Binding SensorB}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Numeric Up Down Control for Standard Deviation -->
        <Label Content="Sigma" HorizontalAlignment="Left" Margin="14,19,0,0" VerticalAlignment="Top" FontSize="10" FontFamily="Century Gothic"/>
        <Border BorderThickness="0.5" BorderBrush="Gray" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18,37,0,0" Height="20" Width="78">
            <wpfx:IntegerUpDown x:Name="txtSigma" Text="10" Padding="10 0 0 0" VerticalAlignment="Center" FontSize="10" Background="Transparent" Height="20" TextAlignment="Left" 
                                FontFamily="Century Gothic" HorizontalAlignment="Center" Width="78" BorderThickness="0" FormatString="N0" Minimum="10" Maximum="20"/> <!-- 4.13 Sigma Minimum=10, Maximum=20, Default=10-->
        </Border>

        <!-- Numeric Up Down Control for Mean -->
        <Label Content="Mu" HorizontalAlignment="Left" Margin="114,19,0,0" VerticalAlignment="Top" FontFamily="Century Gothic" FontSize="10"/>
        <Border BorderThickness="0.5" BorderBrush="Gray" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="118,37,0,0" Height="20" Width="78">
            <wpfx:IntegerUpDown x:Name="txtMean" Text="50" Padding="10 0 0 0" VerticalAlignment="Center" FontSize="10" Background="Transparent" Height="20" TextAlignment="Left"
                                    FontFamily="Century Gothic" HorizontalAlignment="Center" Width="78" BorderThickness="0" FormatString="N0" Minimum="35" Maximum="75"/> <!--4.13 Mean Minimum=35, Maximum=75, Default=50-->
        </Border>
        
        <!-- Button to Load Sensor Data -->
        <Button x:Name="btnLoadData" Content="Load Sensor Data" FontFamily="Century Gothic" FontSize="10" HorizontalAlignment="Left" Margin="37,66,0,0" VerticalAlignment="Top" Height="20" Width="144" Click="btnLoadData_Click"/>
        
        <!-- Sensor A Controls -->
        <Label Content="Sensor A" HorizontalAlignment="Left" Margin="236,20,0,0" VerticalAlignment="Top" FontFamily="Century Gothic" FontSize="20"/>
        
        <!-- Sensor A: Binary Search Iterative Controls -->
        <Label Content="Binary Search Iterative" HorizontalAlignment="Left" Margin="236,60,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtBinaryIterativeA" HorizontalAlignment="Left" Margin="241,102,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only -->
        <Button Content="Search" HorizontalAlignment="Left" Margin="241,80,0,0" VerticalAlignment="Top" Width="72" FontSize="10" Click="btnBinarySearchIterativeA_Click" FontFamily="Century Gothic"/>

        <!-- Sensor A: Binary Search Recursive Controls -->
        <Label Content="Binary Search Recursive" HorizontalAlignment="Left" Margin="236,137,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtBinaryRecursiveA" HorizontalAlignment="Left" Margin="241,179,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only -->
        <Button Content="Search" HorizontalAlignment="Left" Margin="241,157,0,0" VerticalAlignment="Top" Width="72" FontSize="10" Click="btnBinarySearchRecursiveA_Click" FontFamily="Century Gothic"/>

        <!-- Sensor A: Search Target -->
        <Label Content="Search Target" HorizontalAlignment="Left" Margin="236,218,0,0" VerticalAlignment="Top" Width="81" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtTargetA" HorizontalAlignment="Left" Margin="317,222,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="52" RenderTransformOrigin="0.5,0.705" FontSize="10" FontFamily="Century Gothic"
                 PreviewTextInput="NumericOnly_PreviewTextInput"/>

        <!-- Sensor A: Selection Sort Controls -->
        <Label Content="Selection Sort" HorizontalAlignment="Left" Margin="236,262,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtSelectionSortA" HorizontalAlignment="Left" Margin="241,303,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only -->
        <Button Content="Sort" HorizontalAlignment="Left" Margin="241,281,0,0" VerticalAlignment="Top" Width="72" FontSize="10" Click="btnSelectionSortA_Click" FontFamily="Century Gothic"/>

        <!-- Sensor A: Insertion Sort Controls -->
        <Label Content="Insertion Sort" HorizontalAlignment="Left" Margin="236,333,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtInsertionSortA" HorizontalAlignment="Left" Margin="241,374,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only -->
        <Button Content="Sort" HorizontalAlignment="Left" Margin="241,352,0,0" VerticalAlignment="Top" Width="72" FontSize="10" Click="btnInsertionSortA_Click"  FontFamily="Century Gothic"/>
        
        <!-- Sensor A Listbox -->
        <ListBox x:Name="lstSensorA" SelectionMode="Multiple" Margin="384,60,298,10" FontFamily="Century Gothic"/>

        <!-- Sensor B Controls -->
        <Label Content="Sensor B" HorizontalAlignment="Left" Margin="526,20,0,0" VerticalAlignment="Top" FontFamily="Century Gothic" FontSize="20" RenderTransformOrigin="0.539,0.957"/>

        <!-- Sensor B: Binary Search Iterative Controls -->
        <Label Content="Binary Search Iterative" HorizontalAlignment="Left" Margin="524,60,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtBinaryIterativeB" HorizontalAlignment="Left" Margin="529,102,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only-->
        <Button Content="Search" HorizontalAlignment="Left" Margin="529,80,0,0" VerticalAlignment="Top" Width="72" FontSize="10" FontFamily="Century Gothic"/>

        <!-- Sensor B: Binary Search Recursive Controls -->
        <Label Content="Binary Search Recursive" HorizontalAlignment="Left" Margin="524,133,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtBinaryRecursiveB" HorizontalAlignment="Left" Margin="529,175,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only -->
        <Button Content="Search" HorizontalAlignment="Left" Margin="529,153,0,0" VerticalAlignment="Top" Width="72" FontSize="10" FontFamily="Century Gothic"/>

        <!-- Sensor B: Search Target -->
        <Label Content="Search Target" HorizontalAlignment="Left" Margin="526,214,0,0" VerticalAlignment="Top" Width="81" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtTargetB" HorizontalAlignment="Left" Margin="607,218,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="52" RenderTransformOrigin="0.5,0.705" FontSize="10" FontFamily="Century Gothic"
                 PreviewTextInput="NumericOnly_PreviewTextInput"/>

        <!-- Sensor B: Selection Sort -->
        <Label Content="Selection Sort" HorizontalAlignment="Left" Margin="524,258,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtSelectionSortB" HorizontalAlignment="Left" Margin="529,299,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only -->
        <Button Content="Sort" HorizontalAlignment="Left" Margin="529,277,0,0" VerticalAlignment="Top" Width="72" FontSize="10" FontFamily="Century Gothic"/>

        <!-- Sensor B: Insertion Sort -->
        <Label Content="Insertion Sort" HorizontalAlignment="Left" Margin="524,329,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.263,-0.422" Height="23" FontSize="10" FontFamily="Century Gothic"/>
        <TextBox x:Name="txtInsertionSortB" HorizontalAlignment="Left" Margin="529,370,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontSize="10" FontFamily="Century Gothic" IsReadOnly="True"/> <!-- Read Only -->
        <Button Content="Sort" HorizontalAlignment="Left" Margin="529,348,0,0" VerticalAlignment="Top" Width="72" FontSize="10" FontFamily="Century Gothic"/>
        
        <!-- Sensor B Listbox -->
        <ListBox x:Name="lstSensorB" SelectionMode="Multiple" Margin="672,60,10,10" FontFamily="Century Gothic"/>
        





    </Grid>
</Window>
